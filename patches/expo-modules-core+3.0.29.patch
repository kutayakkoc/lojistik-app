+  CAST_AND_RETURN(jni::JInteger, cache.jInteger.clazz)
+  CAST_AND_RETURN(jni::JLong, cache.jLong.clazz)
+  CAST_AND_RETURN(jni::JString, cache.jString)
+  CAST_AND_RETURN(jni::JBoolean, cache.jBoolean.clazz)
