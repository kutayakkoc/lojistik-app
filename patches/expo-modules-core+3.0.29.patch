+jobject JCache::getJUndefined(JNIEnv *env) {
+  jclass clazz = env->FindClass("expo/modules/kotlin/types/ValueOrUndefined");
+  jmethodID methodId = env->GetStaticMethodID(clazz, "getUndefined", "()Ljava/lang/Object;");
